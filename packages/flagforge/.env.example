# Connection string for Postgres (host port 5435).
DATABASE_URL=postgres://flagforge:flagforge@localhost:5435/flagforge

# Redis connection string (host port 6380). Leave unset to use NullCache (no caching).
REDIS_URL=redis://localhost:6380

# Shared API key required on every request via the x-api-key header (except /healthz, /docs, /admin).
API_KEY=dev-flagforge-key

PORT=8081
LOG_LEVEL=info
