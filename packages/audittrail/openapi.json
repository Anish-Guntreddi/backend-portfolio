{
  "openapi": "3.0.3",
  "info": {
    "title": "AuditTrail",
    "version": "0.1.0",
    "description": "Immutable, append-only, tamper-evident audit logging."
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "x-api-key",
        "in": "header"
      }
    },
    "schemas": {}
  },
  "paths": {
    "/events": {
      "post": {
        "summary": "Append an audit event to the immutable log",
        "tags": [
          "events"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "actor": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 512
                  },
                  "action": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 512
                  },
                  "resource": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 1024
                  },
                  "occurredAt": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "ip": {
                    "type": "string",
                    "anyOf": [
                      {
                        "format": "ipv4"
                      },
                      {
                        "format": "ipv6"
                      }
                    ]
                  },
                  "metadata": {
                    "type": "object",
                    "additionalProperties": {}
                  }
                },
                "required": [
                  "actor",
                  "action",
                  "resource"
                ],
                "additionalProperties": false
              }
            }
          }
        },
        "security": [
          {
            "apiKey": []
          }
        ],
        "responses": {
          "201": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "number"
                    },
                    "actor": {
                      "type": "string"
                    },
                    "action": {
                      "type": "string"
                    },
                    "resource": {
                      "type": "string"
                    },
                    "occurredAt": {
                      "type": "string"
                    },
                    "recordedAt": {
                      "type": "string"
                    },
                    "ip": {
                      "type": "string",
                      "nullable": true
                    },
                    "metadata": {
                      "type": "object",
                      "additionalProperties": {}
                    },
                    "prevHash": {
                      "type": "string"
                    },
                    "hash": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "actor",
                    "action",
                    "resource",
                    "occurredAt",
                    "recordedAt",
                    "ip",
                    "metadata",
                    "prevHash",
                    "hash"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "Search and filter events (keyset pagination, newest first)",
        "tags": [
          "events"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "actor",
            "required": false
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "action",
            "required": false
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "resource",
            "required": false
          },
          {
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "in": "query",
            "name": "from",
            "required": false
          },
          {
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "in": "query",
            "name": "to",
            "required": false
          },
          {
            "schema": {
              "type": "integer",
              "exclusiveMinimum": true,
              "minimum": 0
            },
            "in": "query",
            "name": "cursor",
            "required": false
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 500
            },
            "in": "query",
            "name": "limit",
            "required": false
          }
        ],
        "security": [
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "number"
                          },
                          "actor": {
                            "type": "string"
                          },
                          "action": {
                            "type": "string"
                          },
                          "resource": {
                            "type": "string"
                          },
                          "occurredAt": {
                            "type": "string"
                          },
                          "recordedAt": {
                            "type": "string"
                          },
                          "ip": {
                            "type": "string",
                            "nullable": true
                          },
                          "metadata": {
                            "type": "object",
                            "additionalProperties": {}
                          },
                          "prevHash": {
                            "type": "string"
                          },
                          "hash": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "id",
                          "actor",
                          "action",
                          "resource",
                          "occurredAt",
                          "recordedAt",
                          "ip",
                          "metadata",
                          "prevHash",
                          "hash"
                        ],
                        "additionalProperties": false
                      }
                    },
                    "nextCursor": {
                      "type": "number",
                      "nullable": true
                    }
                  },
                  "required": [
                    "items",
                    "nextCursor"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/events/export": {
      "get": {
        "summary": "Export filtered events as JSON or CSV",
        "tags": [
          "events"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "actor",
            "required": false
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "action",
            "required": false
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "resource",
            "required": false
          },
          {
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "in": "query",
            "name": "from",
            "required": false
          },
          {
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "in": "query",
            "name": "to",
            "required": false
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "csv"
              ],
              "default": "json"
            },
            "in": "query",
            "name": "format",
            "required": false
          }
        ],
        "security": [
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/events/{id}": {
      "get": {
        "summary": "Fetch a single event by id",
        "tags": [
          "events"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "exclusiveMinimum": true,
              "minimum": 0
            },
            "in": "path",
            "name": "id",
            "required": true
          }
        ],
        "security": [
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "number"
                    },
                    "actor": {
                      "type": "string"
                    },
                    "action": {
                      "type": "string"
                    },
                    "resource": {
                      "type": "string"
                    },
                    "occurredAt": {
                      "type": "string"
                    },
                    "recordedAt": {
                      "type": "string"
                    },
                    "ip": {
                      "type": "string",
                      "nullable": true
                    },
                    "metadata": {
                      "type": "object",
                      "additionalProperties": {}
                    },
                    "prevHash": {
                      "type": "string"
                    },
                    "hash": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "actor",
                    "action",
                    "resource",
                    "occurredAt",
                    "recordedAt",
                    "ip",
                    "metadata",
                    "prevHash",
                    "hash"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/verify": {
      "get": {
        "summary": "Verify the entire audit chain is intact and tamper-free",
        "tags": [
          "integrity"
        ],
        "security": [
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "valid": {
                      "type": "boolean"
                    },
                    "checkedCount": {
                      "type": "number"
                    },
                    "headHash": {
                      "type": "string"
                    },
                    "brokenAtId": {
                      "type": "number"
                    },
                    "reason": {
                      "type": "string"
                    },
                    "expected": {
                      "type": "string"
                    },
                    "actual": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "valid",
                    "checkedCount"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/alert-rules": {
      "post": {
        "summary": "Create an alert rule",
        "tags": [
          "alerts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256
                  },
                  "matchAction": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 512
                  },
                  "threshold": {
                    "type": "integer",
                    "exclusiveMinimum": true,
                    "minimum": 0
                  },
                  "windowSeconds": {
                    "type": "integer",
                    "exclusiveMinimum": true,
                    "minimum": 0,
                    "maximum": 86400
                  },
                  "groupByActor": {
                    "type": "boolean"
                  },
                  "enabled": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "name",
                  "matchAction",
                  "threshold",
                  "windowSeconds"
                ],
                "additionalProperties": false
              }
            }
          }
        },
        "security": [
          {
            "apiKey": []
          }
        ],
        "responses": {
          "201": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "number"
                    },
                    "name": {
                      "type": "string"
                    },
                    "enabled": {
                      "type": "boolean"
                    },
                    "matchAction": {
                      "type": "string"
                    },
                    "groupByActor": {
                      "type": "boolean"
                    },
                    "threshold": {
                      "type": "number"
                    },
                    "windowSeconds": {
                      "type": "number"
                    },
                    "createdAt": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "name",
                    "enabled",
                    "matchAction",
                    "groupByActor",
                    "threshold",
                    "windowSeconds",
                    "createdAt"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List alert rules",
        "tags": [
          "alerts"
        ],
        "security": [
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "number"
                      },
                      "name": {
                        "type": "string"
                      },
                      "enabled": {
                        "type": "boolean"
                      },
                      "matchAction": {
                        "type": "string"
                      },
                      "groupByActor": {
                        "type": "boolean"
                      },
                      "threshold": {
                        "type": "number"
                      },
                      "windowSeconds": {
                        "type": "number"
                      },
                      "createdAt": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "id",
                      "name",
                      "enabled",
                      "matchAction",
                      "groupByActor",
                      "threshold",
                      "windowSeconds",
                      "createdAt"
                    ],
                    "additionalProperties": false
                  }
                }
              }
            }
          }
        }
      }
    },
    "/alerts": {
      "get": {
        "summary": "List triggered alerts (newest first)",
        "tags": [
          "alerts"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 500
            },
            "in": "query",
            "name": "limit",
            "required": false
          }
        ],
        "security": [
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "number"
                      },
                      "ruleId": {
                        "type": "number"
                      },
                      "actor": {
                        "type": "string",
                        "nullable": true
                      },
                      "matchedCount": {
                        "type": "number"
                      },
                      "windowStart": {
                        "type": "string"
                      },
                      "windowEnd": {
                        "type": "string"
                      },
                      "triggeredAt": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "id",
                      "ruleId",
                      "actor",
                      "matchedCount",
                      "windowStart",
                      "windowEnd",
                      "triggeredAt"
                    ],
                    "additionalProperties": false
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}