# Superuser/owner connection used for migrations, runtime queries, and tests.
DATABASE_URL=postgres://audittrail:audittrail@localhost:5434/audittrail

# Least-privilege role (SELECT + INSERT only) created by the append-only-guard migration.
# Used by the integration test to prove UPDATE/DELETE are rejected at the grant level.
APP_DATABASE_URL=postgres://audittrail_app:audittrail_app@localhost:5434/audittrail

# Shared API key required on every request via the x-api-key header (except /healthz and /docs).
API_KEY=dev-audittrail-key

PORT=8080
LOG_LEVEL=info

# How often (seconds) the in-process scheduler evaluates alert rules.
ALERT_EVAL_INTERVAL_SECONDS=30
