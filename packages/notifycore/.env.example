# Connection string for Postgres (host port 5436).
DATABASE_URL=postgres://notifycore:notifycore@localhost:5436/notifycore

# Redis connection string (host port 6381). Required — used by BullMQ worker.
REDIS_URL=redis://localhost:6381

# Shared API key required on every request via the x-api-key header (except /healthz, /docs, /admin).
API_KEY=dev-notifycore-key

PORT=8082
LOG_LEVEL=info

# Worker / retry config
RETRY_BASE_MS=1000
DEFAULT_MAX_ATTEMPTS=5
